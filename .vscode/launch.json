{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "运行 (无调试)",
            "type": "node-terminal",
            "request": "launch",
            "preLaunchTask": "build",
            "command": "dotnet run",
            "cwd": "${workspaceFolder}",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s/swagger"
            }
        }
    ]
}
